<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_annonce_ignore_wizard_form" model="ir.ui.view">
            <field name="name">gespro.annonce.ignore.wizard.form</field>
            <field name="model">gespro.annonce.ignore.wizard</field>
            <field name="arch" type="xml">
                <form string="Motif du refus">
                    <sheet>
                        <group>
                            <p class="text-danger">
                                Vous allez refuser cette annonce.
                                Veuillez obligatoirement indiquer le motif.
                            </p>
                            <field name="annonce_id" invisible="1"/>
                            <field name="motif" required="1"/>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_confirm" string="Confirmer le refus"
                                type="object" class="btn-danger"/>
                        <button string="Annuler" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

    </data>
</odoo>