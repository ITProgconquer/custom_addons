<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ============================================ -->
        <!-- VUE FORMULAIRE                               -->
        <!-- ============================================ -->
        <record id="view_appel_form" model="ir.ui.view">
            <field name="name">gespro.appel.form</field>
            <field name="model">gespro.appel</field>
            <field name="arch" type="xml">
                <form string="Appel à Concurrence">
                    <header>
                        <button name="action_generate_lots" string="Générer les Lots" type="object"
                                class="btn-primary"
                                groups="GesPro.group_pm"
                                invisible="show_generate_lots == False"/>
                        <button name="action_valider" string="Valider (Final)" type="object"
                                class="btn-success"
                                groups="GesPro.group_ceo"
                                invisible="state != 'en_preparation'"/>
                        <button name="action_soumettre" string="Soumettre" type="object"
                                class="btn-primary"
                                groups="GesPro.group_pm,GesPro.group_resadmin"
                                invisible="state != 'pret'"/>
                        <button name="action_gagne" string="Gagné" type="object"
                                class="btn-success"
                                groups="GesPro.group_pm,GesPro.group_resadmin"
                                invisible="state != 'soumis'"/>
                        <button name="action_perdu" string="Perdu" type="object"
                                class="btn-danger"
                                groups="GesPro.group_pm,GesPro.group_resadmin"
                                invisible="state != 'soumis'"/>
                        <button name="action_annuler" string="Annuler" type="object"
                                class="btn-secondary"
                                groups="GesPro.group_ceo"
                                invisible="state in ['gagne', 'perdu', 'annule']"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name" readonly="1"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="annonce_id" invisible="1"/>
                                <field name="pm_id" readonly="1"/>
                                <field name="titre"/>
                                <field name="type_appel"/>
                                <field name="lot_count" invisible="type_appel != 'allotti'"/>
                                <field name="procedure"/>
                                <field name="source"/>
                            </group>
                            <group>
                                <field name="date_publication"/>
                                <field name="deadline"/>
                                <field name="delai_restant" readonly="1"/>
                                <field name="progression_generale" widget="progressbar"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Lots">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h4 class="mb-0">
                                        <i class="fa fa-users text-primary me-2"></i>
                                        Lots  
                                    </h4>
                                </div>
                                <field name="lot_ids">
                                    <list editable="bottom" class="o_list_jira">
                                        <field name="lot_num" string="N°"/>
                                        <field name="titre" string="Lot"/>
                                        <field name="is_ready" string="✅ Prêt" widget="boolean_toggle"/>
                                        <button name="action_open_lot" string="📋 Détails" type="object" 
                                                class="btn btn-sm btn-primary"/>
                                    </list>
                                </field>               
                            </page>
                           <page string="Checklists">
                                <group>
                                    <div class="row g-3 mb-3">
                                        <div class="col-4">
                                            <div class="card border-0 shadow-sm rounded-3 p-3 text-center">
                                                <span class="text-muted small">🔧 Technique</span>
                                                <h3 class="fw-bold text-primary mb-2"><field name="progression_tech"/>%</h3>
                                                <field name="progression_tech" widget="progressbar"/>
                                            </div>
                                        </div>
                                        <div class="col-4">
                                            <div class="card border-0 shadow-sm rounded-3 p-3 text-center">
                                                <span class="text-muted small">📋 Admin</span>
                                                <h3 class="fw-bold text-danger mb-2"><field name="progression_admin"/>%</h3>
                                                <field name="progression_admin" widget="progressbar"/>
                                            </div>
                                        </div>
                                        <div class="col-4">
                                            <div class="card border-0 shadow-sm rounded-3 p-3 text-center">
                                                <span class="text-muted small">💰 Financier</span>
                                                <h3 class="fw-bold text-success mb-2"><field name="progression_fin"/>%</h3>
                                                <field name="progression_fin" widget="progressbar"/>
                                            </div>
                                        </div>
                                    </div>
                                </group>
                                <div class="row g-3">
                                    <!-- Technique -->
                                    <div class="col-4" groups="GesPro.group_ceo,GesPro.group_pm,GesPro.group_tech">
                                        <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
                                            <div class="card-header text-white d-flex justify-content-between align-items-center py-3" 
                                                style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                                                <h5 class="mb-0 fw-bold">🔧 Technique</h5>
                                                <button name="action_add_checklist_item" type="object"
                                                        context="{'default_categorie': 'tech'}"
                                                        class="btn btn-sm btn-light rounded-pill fw-bold">+</button>
                                            </div>
                                            <div class="card-body p-0">
                                                <field name="checklist_tech_ids"
                                                    context="{'default_categorie': 'tech'}">
                                                    <list editable="bottom" class="o_list_jira">
                                                        <field name="libelle" string="Tâche" placeholder="Nouvelle tâche..."/>
                                                        <field name="is_done" string="✅" widget="boolean_toggle"/>
                                                        <field name="responsible_id" string="Assigné à" options="{'no_create': True}"/>
                                                    </list>
                                                </field>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Admin -->
                                    <div class="col-4" groups="GesPro.group_ceo,GesPro.group_pm,GesPro.group_resadmin">
                                        <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
                                            <div class="card-header text-white d-flex justify-content-between align-items-center py-3" 
                                                style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
                                                <h5 class="mb-0 fw-bold">📋 Admin</h5>
                                                <button name="action_add_checklist_item" type="object"
                                                        context="{'default_categorie': 'admin'}"
                                                        class="btn btn-sm btn-light rounded-pill fw-bold">+</button>
                                            </div>
                                            <div class="card-body p-0">
                                                <field name="checklist_admin_ids"
                                                    context="{'default_categorie': 'admin'}">
                                                    <list editable="bottom" class="o_list_jira">
                                                        <field name="libelle" string="Tâche" placeholder="Nouvelle tâche..."/>
                                                        <field name="is_done" string="✅" widget="boolean_toggle"/>
                                                        <field name="responsible_id" string="Assigné à" options="{'no_create': True}"/>
                                                    </list>
                                                </field>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Financier -->
                                    <div class="col-4" groups="GesPro.group_ceo,GesPro.group_pm,GesPro.group_fin">
                                        <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
                                            <div class="card-header text-white d-flex justify-content-between align-items-center py-3" 
                                                style="background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);">
                                                <h5 class="mb-0 fw-bold">💰 Financier</h5>
                                                <button name="action_add_checklist_item" type="object"
                                                        context="{'default_categorie': 'fin'}"
                                                        class="btn btn-sm btn-light rounded-pill fw-bold">+</button>
                                            </div>
                                            <div class="card-body p-0">
                                                <field name="checklist_fin_ids"
                                                    context="{'default_categorie': 'fin'}">
                                                    <list editable="bottom" class="o_list_jira">
                                                        <field name="libelle" string="Tâche" placeholder="Nouvelle tâche..."/>
                                                        <field name="is_done" string="✅" widget="boolean_toggle"/>
                                                        <field name="responsible_id" string="Assigné à" options="{'no_create': True}"/>
                                                    </list>
                                                </field>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </page> 
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- ============================================ -->
        <!-- VUE LISTE                                    -->
        <!-- ============================================ -->
        <record id="view_appel_list" model="ir.ui.view">
            <field name="name">gespro.appel.list</field>
            <field name="model">gespro.appel</field>
            <field name="arch" type="xml">
                <list string="Appels à Concurrence">
                    <field name="name"/>
                    <field name="titre"/>
                    <field name="annonce_id"/>
                    <field name="state" widget="badge"/>
                    <field name="deadline"/>
                    <field name="delai_restant"/>
                    <field name="progression_generale" widget="progressbar"/>
                </list>
            </field>
        </record>

        <!-- ============================================ -->
        <!-- VUE KANBAN                                   -->
        <!-- ============================================ -->
        <record id="view_appel_kanban" model="ir.ui.view">
            <field name="name">gespro.appel.kanban</field>
            <field name="model">gespro.appel</field>
            <field name="arch" type="xml">
                <kanban default_group_by="state">
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_card">
                                <div class="oe_kanban_content">
                                    <h3><field name="name"/></h3>
                                    <div><field name="titre"/></div>
                                    <div>Deadline : <field name="deadline"/></div>
                                    <div>Délai : <field name="delai_restant"/> jours</div>
                                    <field name="progression_generale" widget="progressbar"/>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- ============================================ -->
        <!-- VUE SEARCH                                   -->
        <!-- ============================================ -->
        <record id="view_appel_search" model="ir.ui.view">
            <field name="name">gespro.appel.search</field>
            <field name="model">gespro.appel</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="titre"/>
                    <field name="annonce_id"/>
                    <filter string="En préparation" name="filter_prep" domain="[('state','=','en_preparation')]"/>
                    <filter string="Prêt" name="filter_pret" domain="[('state','=','pret')]"/>
                    <filter string="Soumis" name="filter_soumis" domain="[('state','=','soumis')]"/>
                    <filter string="Gagné" name="filter_gagne" domain="[('state','=','gagne')]"/>
                    <filter string="Perdu" name="filter_perdu" domain="[('state','=','perdu')]"/>
                    <separator/>
                    <filter string="Mes appels" name="filter_my" domain="[('pm_id','=',uid)]"/>
                    <filter string="Urgent (J-2)" name="filter_urgent" domain="[('delai_restant','&lt;=',2)]"/>
                </search>
            </field>
        </record>

        <!-- ============================================ -->
        <!-- ACTION                                       -->
        <!-- ============================================ -->
        <record id="action_appel" model="ir.actions.act_window">
            <field name="name">Appels à Concurrence</field>
            <field name="res_model">gespro.appel</field>
            <field name="view_mode">list,kanban,form</field>
        </record>

    </data>
</odoo>