<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ============================================ -->
        <!-- VUE FORMULAIRE                               -->
        <!-- ============================================ -->
        <record id="view_appel_form" model="ir.ui.view">
            <field name="name">gespro.appel.form</field>
            <field name="model">gespro.appel</field>
            <field name="arch" type="xml">
                <form string="Appel à Concurrence">
                    <header>
                        <button name="action_generate_lots" string="Générer les Lots" type="object"
                                class="btn-primary"
                                groups="GesPro.group_pm"
                                invisible="show_generate_lots == False"/>
                        <button name="action_generate_checklists" string="Générer les Checklists" type="object"
                                class="btn-primary"
                                groups="GesPro.group_pm"
                                invisible="show_generate_checklists == False"/>
                        <button name="action_valider" string="Valider (Final)" type="object"
                                class="btn-success"
                                groups="gespro.group_ceo"
                                invisible="state != 'en_preparation'"/>
                        <button name="action_soumettre" string="Soumettre" type="object"
                                class="btn-primary"
                                groups="GesPro.group_pm,GesPro.group_resadmin"
                                invisible="state != 'pret'"/>
                        <button name="action_gagne" string="Gagné" type="object"
                                class="btn-success"
                                groups="GesPro.group_pm,GesPro.group_resadmin"
                                invisible="state != 'soumis'"/>
                        <button name="action_perdu" string="Perdu" type="object"
                                class="btn-danger"
                                groups="GesPro.group_pm,GesPro.group_resadmin"
                                invisible="state != 'soumis'"/>
                        <button name="action_annuler" string="Annuler" type="object"
                                class="btn-secondary"
                                groups="GesPro.group_ceo"
                                invisible="state in ['gagne', 'perdu', 'annule']"/>
                        <field name="state" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name" readonly="1"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="annonce_id" invisible="1"/>
                                <field name="pm_id" readonly="1"/>
                                <field name="titre"/>
                                <field name="type_appel"/>
                                <field name="lot_count" invisible="type_appel != 'allotti'"/>
                                <field name="procedure"/>
                                <field name="source"/>
                            </group>
                            <group>
                                <field name="date_publication"/>
                                <field name="deadline"/>
                                <field name="delai_restant" readonly="1"/>
                                <field name="progression_generale" widget="progressbar"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Lots">
                                <field name="lot_ids">
                                    <list editable="bottom">
                                        <field name="lot_num" string="N°"/>
                                        <field name="titre" string="Lot"/>
                                        <field name="is_ready" string="✅ Prêt" widget="boolean_toggle"/>
                                    </list>
                                    <form>
                                        <sheet>
                                            <group>
                                                <field name="lot_num"/>
                                                <field name="titre"/>
                                                <field name="is_ready" widget="boolean_toggle"/>
                                            </group>
                                            <notebook>
                                                <page string="👥 Personnel">
                                                    <field name="personnel_line_ids">
                                                        <list editable="bottom">
                                                            <field name="role" string="Poste"/>
                                                            <field name="qualification_min" string="Qualification"/>
                                                            <field name="nb_exige" string="Nb exigé"/>
                                                            <field name="experience_years" string="Expérience"/>
                                                            <field name="is_satisfied" string="✅" widget="boolean_toggle"/>
                                                        </list>
                                                    </field>
                                                </page>
                                                <page string="🔧 Matériel">
                                                    <field name="material_line_ids">
                                                        <list editable="bottom">
                                                            <field name="designation" string="Désignation"/>
                                                            <field name="qty_required" string="Qté exigée"/>
                                                            <field name="qty_provided" string="Qté fournie"/>
                                                            <field name="is_satisfied" string="✅" widget="boolean_toggle"/>
                                                        </list>
                                                    </field>
                                                </page>
                                            </notebook>
                                        </sheet>
                                    </form>
                                </field>
                            </page>
                           <page string="Checklists">
                                <!-- Barres de progression style JIRA -->
                                <group>
                                    <div class="row g-3">
                                        <div class="col-4">
                                            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                                                <div class="card-body text-center py-4" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                                                    <i class="fa fa-code fa-2x text-white mb-2"></i>
                                                    <h5 class="text-white fw-bold mb-0">🔧 Technique</h5>
                                                </div>
                                                <div class="card-footer bg-white border-0 px-4 py-3">
                                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                                        <span class="text-muted small">Progression</span>
                                                        <span class="fw-bold text-primary"><field name="progression_tech"/>%</span>
                                                    </div>
                                                    <field name="progression_tech" widget="progressbar" class="rounded-pill"/>
                                                </div>
                                            </div>
                                        </div>
                                        
                                        <div class="col-4">
                                            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                                                <div class="card-body text-center py-4" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);">
                                                    <i class="fa fa-folder-open fa-2x text-white mb-2"></i>
                                                    <h5 class="text-white fw-bold mb-0">📋 Admin</h5>
                                                </div>
                                                <div class="card-footer bg-white border-0 px-4 py-3">
                                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                                        <span class="text-muted small">Progression</span>
                                                        <span class="fw-bold text-danger"><field name="progression_admin"/>%</span>
                                                    </div>
                                                    <field name="progression_admin" widget="progressbar" class="rounded-pill"/>
                                                </div>
                                            </div>
                                        </div>
                                        
                                        <div class="col-4">
                                            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                                                <div class="card-body text-center py-4" style="background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);">
                                                    <i class="fa fa-dollar fa-2x text-white mb-2"></i>
                                                    <h5 class="text-white fw-bold mb-0">💰 Financier</h5>
                                                </div>
                                                <div class="card-footer bg-white border-0 px-4 py-3">
                                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                                        <span class="text-muted small">Progression</span>
                                                        <span class="fw-bold text-success"><field name="progression_fin"/>%</span>
                                                    </div>
                                                    <field name="progression_fin" widget="progressbar" class="rounded-pill"/>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </group>

                                <!-- Barre de filtres PM -->
                                <div class="d-flex gap-2 my-3" groups="GesPro.group_pm">
                                    <span class="btn btn-sm rounded-pill filter-btn active" data-category="all"
                                        style="background:#1a1a1a; color:white; cursor:pointer;">
                                        📋 Tous
                                    </span>
                                    <span class="btn btn-sm rounded-pill filter-btn" data-category="tech"
                                        style="background:#667eea; color:white; cursor:pointer;">
                                        🔧 Technique
                                    </span>
                                    <span class="btn btn-sm rounded-pill filter-btn" data-category="admin"
                                        style="background:#f5576c; color:white; cursor:pointer;">
                                        📋 Admin
                                    </span>
                                    <span class="btn btn-sm rounded-pill filter-btn" data-category="fin"
                                        style="background:#43e97b; color:white; cursor:pointer;">
                                        💰 Financier
                                    </span>
                                </div>

                                <!-- Liste des checklists -->
                                <div class="mt-3">
                                    <field name="checklist_ids">
                                        <list default_group_by="categorie" editable="bottom" class="o_list_jira">
                                            <field name="categorie" widget="badge" column_invisible="1"/>
                                            <field name="libelle" string="Tâche"/>
                                            <field name="is_done" string="✅" widget="boolean_toggle"/>
                                            <field name="responsible_id" string="Assigné à"/>
                                            <field name="note" string="Commentaire"/>
                                        </list>
                                    </field>
                                </div>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- ============================================ -->
        <!-- VUE LISTE                                    -->
        <!-- ============================================ -->
        <record id="view_appel_list" model="ir.ui.view">
            <field name="name">gespro.appel.list</field>
            <field name="model">gespro.appel</field>
            <field name="arch" type="xml">
                <list string="Appels à Concurrence">
                    <field name="name"/>
                    <field name="titre"/>
                    <field name="annonce_id"/>
                    <field name="state" widget="badge"/>
                    <field name="deadline"/>
                    <field name="delai_restant"/>
                    <field name="progression_generale" widget="progressbar"/>
                </list>
            </field>
        </record>

        <!-- ============================================ -->
        <!-- VUE KANBAN                                   -->
        <!-- ============================================ -->
        <record id="view_appel_kanban" model="ir.ui.view">
            <field name="name">gespro.appel.kanban</field>
            <field name="model">gespro.appel</field>
            <field name="arch" type="xml">
                <kanban default_group_by="state">
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_card">
                                <div class="oe_kanban_content">
                                    <h3><field name="name"/></h3>
                                    <div><field name="titre"/></div>
                                    <div>Deadline : <field name="deadline"/></div>
                                    <div>Délai : <field name="delai_restant"/> jours</div>
                                    <field name="progression_generale" widget="progressbar"/>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- ============================================ -->
        <!-- VUE SEARCH                                   -->
        <!-- ============================================ -->
        <record id="view_appel_search" model="ir.ui.view">
            <field name="name">gespro.appel.search</field>
            <field name="model">gespro.appel</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="titre"/>
                    <field name="annonce_id"/>
                    <filter string="En préparation" name="filter_prep" domain="[('state','=','en_preparation')]"/>
                    <filter string="Prêt" name="filter_pret" domain="[('state','=','pret')]"/>
                    <filter string="Soumis" name="filter_soumis" domain="[('state','=','soumis')]"/>
                    <filter string="Gagné" name="filter_gagne" domain="[('state','=','gagne')]"/>
                    <filter string="Perdu" name="filter_perdu" domain="[('state','=','perdu')]"/>
                    <separator/>
                    <filter string="Mes appels" name="filter_my" domain="[('pm_id','=',uid)]"/>
                    <filter string="Urgent (J-2)" name="filter_urgent" domain="[('delai_restant','&lt;=',2)]"/>
                </search>
            </field>
        </record>

        <!-- ============================================ -->
        <!-- ACTION                                       -->
        <!-- ============================================ -->
        <record id="action_appel" model="ir.actions.act_window">
            <field name="name">Appels à Concurrence</field>
            <field name="res_model">gespro.appel</field>
            <field name="view_mode">list,kanban,form</field>
        </record>

    </data>
</odoo>