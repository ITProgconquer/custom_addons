<odoo>
    <record id="view_depouillement_form" model="ir.ui.view">
        <field name="name">gespro.depouillement.form</field>
        <field name="model">gespro.depouillement</field>
        <field name="arch" type="xml">
            <form string="Dépouillement">
                <sheet>
                    <group>
                        <field name="appel_id" invisible="1"/>
                        <field name="lot_id" widget="many2many_tags" invisible="1"/>
                        <field name="ordre"/>
                        <field name="soumissionnaires"/>
                        <field name="montant_min_ttc"/>
                        <field name="montant_max_ttc"/>
                        <field name="observation"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_depouillement_list" model="ir.ui.view">
        <field name="name">gespro.depouillement.list</field>
        <field name="model">gespro.depouillement</field>
        <field name="arch" type="xml">
            <list string="Dépouillements">
                <field name="ordre"/>
                <field name="soumissionnaires"/>
                <field name="montant_min_ttc"/>
                <field name="montant_max_ttc"/>
                <field name="observation"/>
                <field name="lot_id" invisible="1"/>
            </list>
        </field>
    </record>
</odoo>