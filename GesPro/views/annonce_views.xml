<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_annonce_form" model="ir.ui.view">
        <field name="name">gespro.annonce.form</field>
        <field name="model">gespro.annonce</field>
        <field name="arch" type="xml">
            <form string="Annonce">
                <header>
                    <button name="action_create_appel_offre" string="Créer Appel d'offre" type="object"
                            class="btn-primary"
                            groups="GesPro.group_pm"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="user_id" readonly="1" string="👤 Auteur"/>
                            <field name="date_envoi" readonly="1" string="📅 Date d'envoi"/>
                        </group>
                        <group>
                            <field name="source_file" widget="binary" filename="source_filename"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                        <page string="Appels d'offre" groups="GesPro.group_ceo,GesPro.group_resadmin,GesPro.group_pm">
                            <field name="appel_offre_ids">
                                <list class="o_list_jira">
                                    <field name="name"/>
                                    <field name="titre"/>
                                    <field name="date_butoire"/>
                                    <field name="garantie_soumission"/>
                                    <field name="autorite_contractante"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Vue liste, kanban, search inchangées (mais il faut retirer la colonne state si elle existait) -->
    <record id="view_annonce_list" model="ir.ui.view">
        <field name="name">gespro.annonce.list</field>
        <field name="model">gespro.annonce</field>
        <field name="arch" type="xml">
            <list string="Annonces">
                <field name="display_reference" string="📄 Référence"/>
                <field name="display_author" string="👤 Auteur"/>
                <field name="display_date" string="📅 Date d'envoi"/>
                <button name="open_appel_offre_list" string="📋 Appels d'offre" type="object"
                        class="btn btn-sm btn-primary"/>
            </list>
        </field>
    </record>

    <record id="view_annonce_kanban" model="ir.ui.view">
        <field name="name">gespro.annonce.kanban</field>
        <field name="model">gespro.annonce</field>
        <field name="arch" type="xml">
            <kanban default_group_by="user_id" class="o_kanban_small">
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card">
                            <div class="oe_kanban_content">
                                <h3><field name="name"/></h3>
                                <div><field name="user_id"/></div>
                                <div><field name="date_envoi"/></div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_annonce_search" model="ir.ui.view">
        <field name="name">gespro.annonce.search</field>
        <field name="model">gespro.annonce</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="user_id"/>
                <filter string="Mes annonces" name="filter_my" domain="[('user_id','=',uid)]"/>
            </search>
        </field>
    </record>

    <record id="action_annonce" model="ir.actions.act_window">
        <field name="name">Annonces</field>
        <field name="res_model">gespro.annonce</field>
        <field name="view_mode">list,kanban,form</field>
    </record>

</odoo>