<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================ -->
    <!-- VUE FORMULAIRE                               -->
    <!-- ============================================ -->
    <record id="view_appel_offre_form" model="ir.ui.view">
        <field name="name">gespro.appel.offre.form</field>
        <field name="model">gespro.appel.offre</field>
        <field name="arch" type="xml">
            <form string="Appel d'offre">
                <header>
                        <button name="action_mark_lu" string="Marquer Lu" type="object"
                                class="btn-primary"
                                groups="GesPro.group_ceo"
                                invisible="state != 'nouveau'"/>
                        <button name="action_investigation" string="Demander Investigation" type="object"
                                class="btn-warning"
                                groups="GesPro.group_ceo"
                                invisible="state != 'lu'"/>
                        <button name="action_generate_lots" string="Générer les Lots" type="object"
                                class="btn-primary"
                                groups="GesPro.group_pm"
                                invisible="not show_generate_lots"/>


<!-- GO visible si l'état est lu, en investigation, ou déjà no_go (pour revenir) -->
                        <button name="action_go" string="GO" type="object" class="btn-success"
                                groups="GesPro.group_ceo"
                                invisible="state not in ['lu', 'en_investigation', 'no_go']"/>

<!-- NO GO visible si l'état est lu, en investigation, ou déjà go (pour revenir) -->
                        <button name="action_no_go" string="NO GO" type="object" class="btn-danger"
                                groups="GesPro.group_ceo"
                                invisible="state not in ['lu', 'en_investigation', 'go']"/>
                        
                        <button name="action_ignore" string="Ignorer" type="object"
                                class="btn-secondary"
                                groups="GesPro.group_ceo"
                                invisible="state not in ['nouveau', 'lu']"/>
                        <button name="action_create_appel_concurrence" string="Créer AC" type="object"
                                class="btn-primary"
                                groups="GesPro.group_pm"
                                invisible="not show_create_ac"/>
                        <button name="action_create_payment" string="Enregistrer paiement" type="object"
                                class="btn-primary"
                                groups="GesPro.group_resadmin"
                                invisible="state != 'go'"/>
                                
                        <button name="action_send_investigation_result" 
                                string="Transmettre le résultat" 
                                type="object" 
                                class="btn-warning"
                                invisible="state != 'en_investigation'"
                                groups="GesPro.group_resadmin"/>        
                        <field name="state" widget="statusbar"/>
                    </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="annonce_id" invisible="1"/>
                            <field name="pm_id" readonly="1"/>
                            <field name="autorite_contractante"/>
                            <field name="titre"/>
                            <field name="garantie_soumission"/>
                            <field name="ligne_de_credit"/>
                            <field name="chiffre_affaire"/>
                            <field name="frais_des_doosiers"/>
                        </group>
                        <group>
                            <field name="type_appel"/>
                            <field name="lot_count" invisible="type_appel != 'allotti'"/>
                            <field name="date_butoire"/>
                            <field name="visite_site"/>
                            <field name="type_offre" string="Type" required="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Captures" groups="GesPro.group_ceo,GesPro.group_resadmin,GesPro.group_pm, GesPro.group_tech, GesPro.group_fin" >
                             <p class="text-muted">Captures d'écran ou documents liés à l'appel d'offre.</p>
                             <field name="capture" widget="image" class="oe_avatar"/>
                        </page>
                       <page string="Appel à Concurrence" groups="GesPro.group_ceo,GesPro.group_resadmin,GesPro.group_pm, GesPro.group_tech, GesPro.group_fin" invisible="can_create_appel == False">
                            <div class="text-center py-4">
                                <!-- AC déjà créé → bouton pour y accéder -->
                                <button name="open_appel_concurrence" 
                                        string="📁 Voir l'Appel à Concurrence" 
                                        type="object"
                                        class="btn btn-primary btn-lg"
                                        invisible="not appel_concurrence_ids"/>
                                <!-- Pas encore d'AC → bouton pour créer -->
                                <button name="action_create_appel_concurrence" 
                                        string="📁 Créer l'Appel à Concurrence" 
                                        type="object"
                                        class="btn btn-success btn-lg"
                                        invisible="appel_concurrence_ids"/>
                            </div>
                        </page>
                         <page string="Paiements" groups="GesPro.group_ceo,GesPro.group_resadmin" invisible="state != 'go'">
                            <field name="payment_ids">
                                <list class="o_list_jira">
                                    <field name="amount"/>
                                    <field name="state" widget="badge"/>
                                    <field name="payment_date"/>
                                </list>
                            </field>
                        </page>

                        <page string="Dossiers" groups="GesPro.group_pm,GesPro.group_ceo,GesPro.group_resadmin, GesPro.group_tech, GesPro.group_fin" 
                            invisible="can_create_appel == False">
                            <p class="text-muted">Dossiers complets acquis par le RESADMIN.</p>
                            <field name="payment_ids">
                                <list editable="bottom" class="o_list_jira">
                                    <field name="state" widget="badge"/>
                                    <field name="document_files" widget="many2many_binary"/>
                                </list>
                            </field>
                        </page>
                        <page string="Investigation" groups="GesPro.group_ceo,GesPro.group_resadmin" invisible="state != 'en_investigation'">
                            <field name="investigation_result_ids" widget="many2many_binary"/>
                        </page>

                        <page string="Lots" invisible="type_appel != 'allotti'">
                            <field name="lot_ids">
                                <list editable="bottom">
                                    <field name="lot_num" string="N°"/>
                                    <field name="titre" string="Titre du lot"/>
                                </list>
                            </field>
                        </page>
                        
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ============================================ -->
    <!-- VUE LISTE                                    -->
    <!-- ============================================ -->
    <record id="view_appel_offre_list" model="ir.ui.view">
        <field name="name">gespro.appel.offre.list</field>
        <field name="model">gespro.appel.offre</field>
        <field name="arch" type="xml">
            <list string="Appels d'offre">
                <field name="name" string="📄 Référence"/>
                <field name="titre" string="📋 Offre"/>
                <field name="autorite_contractante" string="🏛 Autorité"/>
                <field name="date_butoire" string="📅 Date butoire"/>
                <field name="garantie_soumission" string="💰 Garantie"/>
                <field name="state" string="🏷 Statut" widget="badge"
                    decoration-success="state == 'go'"
                    decoration-danger="state == 'no_go'"
                    decoration-warning="state == 'en_investigation'"
                    decoration-info="state == 'lu'"/>
                <field name="annonce_id" string="📁 Annonce"/>
            </list>
        </field>
    </record>



    <!-- ============================================ -->
    <!-- VUE KANBAN                                   -->
    <!-- ============================================ -->
    <record id="view_appel_offre_kanban" model="ir.ui.view">
        <field name="name">gespro.appel.offre.kanban</field>
        <field name="model">gespro.appel.offre</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small">
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card" t-attf-style="border-left: 4px solid #{record.state.raw_value == 'go' and '#2e7d32' or record.state.raw_value == 'no_go' and '#c62828' or record.state.raw_value == 'en_investigation' and '#e65100' or record.state.raw_value == 'lu' and '#0277bd' or '#9e9e9e'}">
                            <div class="oe_kanban_content">
                                <h3><field name="titre"/></h3>
                                <div>🏛 <field name="autorite_contractante"/></div>
                                <div>📅 <field name="date_butoire"/></div>
                                <div>💰 <field name="garantie_soumission"/></div>
                                <div>🏷 <field name="state" widget="badge"/></div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>

        </field>
    </record>

    <!-- ============================================ -->
    <!-- VUE SEARCH                                   -->
    <!-- ============================================ -->
    <record id="view_appel_offre_search" model="ir.ui.view">
        <field name="name">gespro.appel.offre.search</field>
        <field name="model">gespro.appel.offre</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="titre"/>
                <field name="autorite_contractante"/>
                <field name="annonce_id"/>
                <filter string="Nouveau" name="filter_new" domain="[('state','=','new')]"/>
                <filter string="Lu" name="filter_lu" domain="[('state','=','lu')]"/>
                <filter string="En investigation" name="filter_inv" domain="[('state','=','en_investigation')]"/>
                <filter string="GO" name="filter_go" domain="[('state','=','go')]"/>
                <filter string="NO GO" name="filter_nogo" domain="[('state','=','no_go')]"/>
                <separator/>
                <filter string="Mes appels d'offre" name="filter_my" domain="[('pm_id','=',uid)]"/>
            </search>
        </field>
    </record>

    <!-- ============================================ -->
    <!-- ACTION                                       -->
    <!-- ============================================ -->
    <record id="action_appel_offre" model="ir.actions.act_window">
        <field name="name">Appels d'offre</field>
        <field name="res_model">gespro.appel.offre</field>
        <field name="view_mode">list,kanban,form</field>
    </record>

</odoo>