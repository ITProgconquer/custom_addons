<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_similar_contract_form" model="ir.ui.view">
            <field name="name">gespro.similar.contract.form</field>
            <field name="model">gespro.similar.contract</field>
            <field name="arch" type="xml">
                <form string="Marché Similaire">
                    <sheet>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="appel_id"/>
                            <field name="contract_date"/>
                            <field name="contract_type"/>
                            <field name="client_name"/>
                            <field name="amount" widget="monetary"/>
                            <field name="document" widget="binary"/>
                            <field name="description"/>
                            <field name="active"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="view_similar_contract_list" model="ir.ui.view">
            <field name="name">gespro.similar.contract.list</field>
            <field name="model">gespro.similar.contract</field>
            <field name="arch" type="xml">
                <list string="Marchés Similaires">
                    <field name="name"/>
                    <field name="client_name"/>
                    <field name="contract_type"/>
                    <field name="contract_date"/>
                    <field name="amount"/>
                </list>
            </field>
        </record>
        <record id="action_similar_contract" model="ir.actions.act_window">
            <field name="name">Marchés Similaires</field>
            <field name="res_model">gespro.similar.contract</field>
            <field name="view_mode">list,form</field>
        </record>
    </data>
</odoo>