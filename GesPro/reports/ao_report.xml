<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="action_report_appel" model="ir.actions.report">
            <field name="name">Rapport Appel à Concurrence</field>
            <field name="model">gespro.appel</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">gespro.report_appel</field>
            <field name="report_file">gespro.report_appel</field>
            <field name="binding_model_id" ref="model_gespro_appel"/>
            <field name="binding_type">report</field>
        </record>

        <template id="report_appel_template">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <div class="page">
                        <h1>Appel à Concurrence</h1>
                        <p><strong>Référence :</strong> <span t-field="doc.name"/></p>
                        <p><strong>Titre :</strong> <span t-field="doc.titre"/></p>
                        <p><strong>Date limite :</strong> <span t-field="doc.deadline"/></p>
                        <p><strong>Statut :</strong> <span t-field="doc.state"/></p>
                    </div>
                </t>
            </t>
        </template>

    </data>
</odoo>