<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="mail_template_alert_j5" model="mail.template">
        <field name="name">Alerte J-5</field>
        <field name="model_id" ref="model_gespro_appel"/>
        <field name="subject">⚠️ [J-5] Deadline approaching: {{ object.titre }}</field>
        <field name="email_to">{{ object.pm_id.email }}</field>
        <field name="body_html">
            <p>Hello,</p>
            <p>The call for tender <strong>{{ object.name }}</strong> expires in 5 days.</p>
            <p>Deadline: {{ object.deadline }}</p>
            <p>Please finalise the dossier.</p>
        </field>
    </record>

    <record id="mail_template_alert_j2" model="mail.template">
        <field name="name">Alerte J-2</field>
        <field name="model_id" ref="model_gespro_appel"/>
        <field name="subject">🚨 [J-2] URGENT: {{ object.titre }}</field>
        <field name="email_to">{{ object.pm_id.email }}</field>
        <field name="body_html">
            <p>⚠️ Attention,</p>
            <p>The call <strong>{{ object.name }}</strong> expires in 2 days.</p>
            <p>Deadline: {{ object.deadline }}</p>
            <p>CEO validation is mandatory.</p>
        </field>
    </record>

    <!-- New: Creation notification -->
    <record id="mail_template_appel_creation" model="mail.template">
        <field name="name">Appel Creation Notification</field>
        <field name="model_id" ref="model_gespro_appel"/>
        <field name="subject">🆕 New Call for Tender: {{ object.name }}</field>
        <field name="email_to">{{ object.pm_id.email }}</field>
        <field name="email_cc">{{ object.annonce_id.user_id.email }}</field>
        <field name="body_html">
            <p>Hello {{ object.pm_id.name }},</p>
            <p>A new Call for Tender has been created:</p>
            <ul>
                <li><strong>Reference:</strong> {{ object.name }}</li>
                <li><strong>Title:</strong> {{ object.titre }}</li>
                <li><strong>Deadline:</strong> {{ object.deadline }}</li>
            </ul>
            <p>You can view it in GESPRO.</p>
        </field>
    </record>

</odoo>