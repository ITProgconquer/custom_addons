<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- 1 - Création Annonce -->
        <record id="mail_template_annonce_creation" model="mail.template">
            <field name="name">Création Annonce</field>
            <field name="model_id" ref="model_gespro_annonce"/>
            <field name="email_from">salomon.zougmore@it-projet.com</field>
            <field name="subject">[GESPRO] Nouvelle annonce : ${object.name}</field>
            <field name="body_html" type="html">
                <p>Bonjour,</p>
                <p>Une nouvelle annonce a été créée par <t t-out="object.user_id.name"/>.</p>
                <p><strong>Référence :</strong> <t t-out="object.name"/><br/><strong>Date :</strong> <t t-out="object.date_envoi"/></p>
                <p>Consultez-la pour voir les Appels d'offres.</p>
            </field>
            <field name="email_to" eval="''"/>
        </record>

        <!-- 2 - Création Appel d'offre -->
        <record id="mail_template_offre_creation" model="mail.template">
            <field name="name">Création Appel d'offre</field>
            <field name="model_id" ref="model_gespro_appel_offre"/>
            <field name="email_from">{{ user.email }}</field>
            <field name="subject">[GESPRO] Nouvel Appel d'offre : {{ object.name }}</field>
            <field name="body_html" type="html">
                <t t-set="base_url" t-value="object.get_base_url()"/>
                <t t-set="record_url" t-value="base_url + '/web#id=%s&amp;model=gespro.appel.offre&amp;view_type=form' % object.id"/>
                <div>
                    <p>Bonjour,</p>
                    <p>L'Appel d'offre <strong><t t-out="object.name"/></strong> a été créé.</p>
                    <p><strong>Titre :</strong> <t t-out="object.titre"/><br/><strong>Date butoir :</strong> <t t-out="object.date_butoire"/></p>
                    <p>PM responsable : <t t-out="object.pm_id.name"/></p>
                    <p>
                        <a t-att-href="record_url" style="color: #c62828; font-weight: bold;">
                            Voir l'Appel d'offre
                        </a>
                    </p>
                </div>
            </field>
            <field name="email_to" eval="''"/>
        </record>

        <!-- 3 - Demande investigation -->
        <record id="mail_template_investigation" model="mail.template">
            <field name="name">Demande Investigation</field>
            <field name="model_id" ref="model_gespro_appel_offre"/>
            <field name="email_from">{{ user.email }}</field>
            <field name="subject">[GESPRO] Investigation demandée : {{ object.name }}</field>
            <field name="body_html" type="html">
                <t t-set="pm_name" t-value="object.pm_id.name if object.pm_id else 'Utilisateur'"/>
                <t t-set="offer_name" t-value="object.name or 'N/A'"/>
                <t t-set="base_url" t-value="object.get_base_url()"/>
                <t t-set="record_url" t-value="base_url + '/web#id=%s&amp;model=gespro.appel.offre&amp;view_type=form' % object.id"/>
                <div>
                    <p>Bonjour <t t-out="pm_name"/>,</p>
                    <p>Le CEO demande une investigation sur l'Appel d'offre <strong><t t-out="offer_name"/></strong>.</p>
                    <t t-if="object.ceo_comment">
                        <p><strong>Instructions du CEO :</strong></p>
                        <div style="white-space: pre-line;">
                            <t t-esc="object.ceo_comment"/>
                        </div>
                    </t>
                    <p>Merci d'analyser le dossier.</p>
                    <p>
                        <a t-att-href="record_url" style="color: #c62828; font-weight: bold;">
                            Accéder à l'Appel d'offre
                        </a>
                    </p>
                </div>
            </field>
            <field name="email_to" eval="''"/>
        </record>

        <!-- 4 - GO Appel d'offre -->
        <record id="mail_template_offre_go" model="mail.template">
            <field name="name">GO Appel d'offre</field>
            <field name="model_id" ref="model_gespro_appel_offre"/>
            <field name="email_from">{{ user.email }}</field>
            <field name="subject">[GESPRO] GO donné : {{ object.name }}</field>
            <field name="body_html" type="html">
                <t t-set="base_url" t-value="object.get_base_url()"/>
                <t t-set="record_url" t-value="base_url + '/web#id=%s&amp;model=gespro.appel.offre&amp;view_type=form' % object.id"/>
                <div>
                    <p>Bonjour,</p>
                    <p>Le CEO a donné son <strong>GO</strong> pour l'Appel d'offre <strong><t t-out="object.name"/></strong>.</p>
                    <p>PM : <t t-out="object.pm_id.name"/><br/>Date butoir : <t t-out="object.date_butoire"/></p>
                    <p>Vous pouvez désormais préparer les Appels à Concurrence.</p>
                    <p>
                        <a t-att-href="record_url" style="color: #c62828; font-weight: bold;">
                            Accéder à l'Appel d'offre
                        </a>
                    </p>
                </div>
            </field>
            <field name="email_to" eval="''"/>
        </record>

        <!-- 5 - NO GO Appel d'offre -->
        <record id="mail_template_offre_nogo" model="mail.template">
            <field name="name">NO GO Appel d'offre</field>
            <field name="model_id" ref="model_gespro_appel_offre"/>
            <field name="email_from">{{ user.email }}</field>
            <field name="subject">[GESPRO] NO GO : {{ object.name }}</field>
            <field name="body_html" type="html">
                <t t-set="base_url" t-value="object.get_base_url()"/>
                <t t-set="record_url" t-value="base_url + '/web#id=%s&amp;model=gespro.appel.offre&amp;view_type=form' % object.id"/>
                <div>
                    <p>Bonjour,</p>
                    <p>Le CEO a refusé l'Appel d'offre <strong><t t-out="object.name"/></strong>.</p>
                    <p>Statut : NO GO.</p>
                    <p>
                        <a t-att-href="record_url" style="color: #c62828; font-weight: bold;">
                            Voir l'Appel d'offre
                        </a>
                    </p>
                </div>
            </field>
            <field name="email_to" eval="''"/>
        </record>

        <!-- 6 - Paiement confirmé -->
        <record id="mail_template_payment_confirmed" model="mail.template">
            <field name="name">Paiement confirmé</field>
            <field name="model_id" ref="model_gespro_appel_offre"/>
            <field name="email_from">{{ user.email }}</field>
            <field name="subject">[GESPRO] Paiement validé : {{ object.name }}</field>
            <field name="body_html" type="html">
                <t t-set="base_url" t-value="object.get_base_url()"/>
                <t t-set="record_url" t-value="base_url + '/web#id=%s&amp;model=gespro.appel.offre&amp;view_type=form' % object.id"/>
                <div>
                    <p>Bonjour,</p>
                    <p>Le paiement de <t t-out="object.payment_ids[-1].amount"/> <t t-out="object.payment_ids[-1].currency_id.name"/> pour l'Appel d'offre <strong><t t-out="object.name"/></strong> a été confirmé.</p>
                    <p>Vous pouvez maintenant créer les Appels à Concurrence.</p>
                    <p>
                        <a t-att-href="record_url" style="color: #c62828; font-weight: bold;">
                            Voir l'Appel d'offre
                        </a>
                    </p>
                </div>
            </field>
            <field name="email_to" eval="''"/>
        </record>

        <!-- 7 - Création AC -->
        <record id="mail_template_appel_creation" model="mail.template">
            <field name="name">Création Appel à Concurrence</field>
            <field name="model_id" ref="model_gespro_appel"/>
            <field name="email_from">{{ user.email }}</field>
            <field name="subject">[GESPRO] Nouvel AC : {{ object.name }}</field>
            <field name="body_html" type="html">
                <t t-set="base_url" t-value="object.get_base_url()"/>
                <t t-set="record_url" t-value="base_url + '/web#id=%s&amp;model=gespro.appel&amp;view_type=form' % object.id"/>
                <div>
                    <p>Bonjour,</p>
                    <p>Un nouvel Appel à Concurrence a été créé.</p>
                    <p><strong>Référence :</strong> <t t-out="object.name"/><br/><strong>Titre :</strong> <t t-out="object.titre"/><br/><strong>Date limite :</strong> <t t-out="object.deadline"/></p>
                    <p>Procédure : <t t-out="object.procedure"/></p>
                    <p>
                        <a t-att-href="record_url" style="color: #c62828; font-weight: bold;">
                            Voir l'Appel à Concurrence
                        </a>
                    </p>
                </div>
            </field>
            <field name="email_to" eval="''"/>
        </record>

        <!-- 10 - Validation dossier prêt -->
        <record id="mail_template_appel_valider" model="mail.template">
            <field name="name">Validation dossier AC</field>
            <field name="model_id" ref="model_gespro_appel"/>
            <field name="email_from">{{ user.email }}</field>
            <field name="subject">[GESPRO] Dossier prêt : {{ object.name }}</field>
            <field name="body_html" type="html">
                <t t-set="base_url" t-value="object.get_base_url()"/>
                <t t-set="record_url" t-value="base_url + '/web#id=%s&amp;model=gespro.appel&amp;view_type=form' % object.id"/>
                <div>
                    <p>Bonjour,</p>
                    <p>Le dossier <strong><t t-out="object.name"/></strong> a été validé par le CEO et est prêt à soumettre.</p>
                    <p>Progression : <t t-out="object.progression_generale"/>%</p>
                    <p>
                        <a t-att-href="record_url" style="color: #c62828; font-weight: bold;">
                            Voir l'Appel à Concurrence
                        </a>
                    </p>
                </div>
            </field>
            <field name="email_to" eval="''"/>
        </record>

        <!-- 11 - Soumission -->
        <record id="mail_template_appel_soumission" model="mail.template">
            <field name="name">Soumission AC</field>
            <field name="model_id" ref="model_gespro_appel"/>
            <field name="email_from">{{ user.email }}</field>
            <field name="subject">[GESPRO] Soumission envoyée : {{ object.name }}</field>
            <field name="body_html" type="html">
                <t t-set="base_url" t-value="object.get_base_url()"/>
                <t t-set="record_url" t-value="base_url + '/web#id=%s&amp;model=gespro.appel&amp;view_type=form' % object.id"/>
                <div>
                    <p>Bonjour,</p>
                    <p>L'Appel à Concurrence <strong><t t-out="object.name"/></strong> a été soumis.</p>
                    <p>Date limite : <t t-out="object.deadline"/></p>
                    <p>Nous attendons le résultat.</p>
                    <p>
                        <a t-att-href="record_url" style="color: #c62828; font-weight: bold;">
                            Voir l'Appel à Concurrence
                        </a>
                    </p>
                </div>
            </field>
            <field name="email_to" eval="''"/>
        </record>

        <!-- 12 - Gagné -->
        <record id="mail_template_appel_gagne" model="mail.template">
            <field name="name">AC Gagné</field>
            <field name="model_id" ref="model_gespro_appel"/>
            <field name="email_from">{{ user.email }}</field>
            <field name="subject">[GESPRO] Félicitations ! {{ object.name }} GAGNÉ</field>
            <field name="body_html" type="html">
                <t t-set="base_url" t-value="object.get_base_url()"/>
                <t t-set="record_url" t-value="base_url + '/web#id=%s&amp;model=gespro.appel&amp;view_type=form' % object.id"/>
                <div>
                    <p>🎉 Bonjour,</p>
                    <p>Nous avons remporté l'Appel à Concurrence <strong><t t-out="object.name"/></strong> !</p>
                    <p>Félicitations à toute l'équipe.</p>
                    <p>
                        <a t-att-href="record_url" style="color: #c62828; font-weight: bold;">
                            Voir l'Appel à Concurrence
                        </a>
                    </p>
                </div>
            </field>
            <field name="email_to" eval="''"/>
        </record>

        <!-- 13 - Perdu -->
        <record id="mail_template_appel_perdu" model="mail.template">
            <field name="name">AC Perdu</field>
            <field name="model_id" ref="model_gespro_appel"/>
            <field name="email_from">{{ user.email }}</field>
            <field name="subject">[GESPRO] Résultat : {{ object.name }} perdu</field>
            <field name="body_html" type="html">
                <t t-set="base_url" t-value="object.get_base_url()"/>
                <t t-set="record_url" t-value="base_url + '/web#id=%s&amp;model=gespro.appel&amp;view_type=form' % object.id"/>
                <div>
                    <p>Bonjour,</p>
                    <p>L'Appel à Concurrence <strong><t t-out="object.name"/></strong> n'a pas été retenu.</p>
                    <p>Merci pour votre travail.</p>
                    <p>
                        <a t-att-href="record_url" style="color: #c62828; font-weight: bold;">
                            Voir l'Appel à Concurrence
                        </a>
                    </p>
                </div>
            </field>
            <field name="email_to" eval="''"/>
        </record>

        <!-- 15 - Alerte J-5 -->
        <record id="mail_template_alert_j5" model="mail.template">
            <field name="name">Alerte J-5</field>
            <field name="model_id" ref="model_gespro_appel"/>
            <field name="subject">[J-5] Deadline approche : {{ object.name }}</field>
            <field name="body_html" type="html">
                <t t-set="base_url" t-value="object.get_base_url()"/>
                <t t-set="record_url" t-value="base_url + '/web#id=%s&amp;model=gespro.appel&amp;view_type=form' % object.id"/>
                <div>
                    <p>Bonjour,</p>
                    <p>L'Appel à Concurrence <strong><t t-out="object.name"/></strong> arrive à échéance dans 5 jours.</p>
                    <p>Date limite : <t t-out="object.deadline"/></p>
                    <p>Merci de finaliser le dossier.</p>
                    <p>
                        <a t-att-href="record_url" style="color: #c62828; font-weight: bold;">
                            Voir l'Appel à Concurrence
                        </a>
                    </p>
                </div>
            </field>
            <field name="email_to" eval="''"/>
        </record>

        <!-- 16 - Alerte J-2 -->
        <record id="mail_template_alert_j2" model="mail.template">
            <field name="name">Alerte J-2</field>
            <field name="model_id" ref="model_gespro_appel"/>
            <field name="subject">[J-2] URGENT : {{ object.name }}</field>
            <field name="body_html" type="html">
                <t t-set="base_url" t-value="object.get_base_url()"/>
                <t t-set="record_url" t-value="base_url + '/web#id=%s&amp;model=gespro.appel&amp;view_type=form' % object.id"/>
                <div>
                    <p>⚠️ Attention,</p>
                    <p>L'Appel <strong><t t-out="object.name"/></strong> expire dans 2 jours.</p>
                    <p>Date limite : <t t-out="object.deadline"/></p>
                    <p>Validation CEO obligatoire.</p>
                    <p>
                        <a t-att-href="record_url" style="color: #c62828; font-weight: bold;">
                            Voir l'Appel à Concurrence
                        </a>
                    </p>
                </div>
            </field>
            <field name="email_to" eval="''"/>
        </record>

        <!-- 17 - Dépouillement terminé -->
        <record id="mail_template_depouillement_termine" model="mail.template">
            <field name="name">Dépouillement terminé</field>
            <field name="model_id" ref="model_gespro_appel"/>
            <field name="subject">[GESPRO] Dépouillement terminé : {{ object.name }}</field>
            <field name="body_html" type="html">
                <t t-set="base_url" t-value="object.get_base_url()"/>
                <t t-set="record_url" t-value="base_url + '/web#id=%s&amp;model=gespro.appel&amp;view_type=form' % object.id"/>
                <div>
                    <p>Bonjour,</p>
                    <p>Le dépouillement de l'Appel à Concurrence <strong><t t-out="object.name"/></strong> est terminé.</p>
                    <p>Consultez les résultats.</p>
                    <p>
                        <a t-att-href="record_url" style="color: #c62828; font-weight: bold;">
                            Voir l'Appel à Concurrence
                        </a>
                    </p>
                </div>
            </field>
            <field name="email_to" eval="''"/>
        </record>

        <!-- Investigation : résultat transmis au CEO -->
        <record id="mail_template_investigation_result" model="mail.template">
            <field name="name">Résultat d'investigation</field>
            <field name="email_from">{{ user.email }}</field>
            <field name="model_id" ref="model_gespro_appel_offre"/>
            <field name="subject">[GESPRO] Résultat d'investigation : {{ object.name }}</field>
            <field name="body_html" type="html">
                <t t-set="base_url" t-value="object.get_base_url()"/>
                <t t-set="record_url" t-value="base_url + '/web#id=%s&amp;model=gespro.appel.offre&amp;view_type=form' % object.id"/>
                <div>
                    <p>Bonjour,</p>
                    <p>Le RESADMIN a transmis le résultat de l'investigation pour l'Appel d'offre <strong><t t-out="object.name"/></strong>.</p>
                    <p>
                        <a t-att-href="record_url" style="color: #c62828; font-weight: bold;">
                            Voir l'investigation
                        </a>
                    </p>
                    <p>Consultez également les documents joints dans GESPRO.</p>
                </div>
            </field>
            <field name="email_to" eval="''"/>
        </record>

    </data>
</odoo>