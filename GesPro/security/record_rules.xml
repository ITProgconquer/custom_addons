<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- PM : ne voit que ses propres appels -->
        <record id="rule_appel_pm" model="ir.rule">
            <field name="name">PM : ses appels uniquement</field>
            <field name="model_id" ref="model_gespro_appel"/>
            <field name="domain_force">[('pm_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_pm'))]"/>
        </record>

        <record id="gespro_attachment_rule" model="ir.rule">
            <field name="name">Gespro Attachments Access</field>
            <field name="model_id" ref="base.model_ir_attachment"/>

            <field name="domain_force">
                [('res_model', 'in', [
                    'gespro.payment',
                    'gespro.annonce',
                    'gespro.appel',
                    'gespro.lot'
                ])]
            </field>

            <field name="groups" eval="[
                (4, ref('group_ceo')),
                (4, ref('group_pm')),
                (4, ref('group_resadmin')),
                (4, ref('group_tech')),
                (4, ref('group_fin'))
            ]"/>
        </record>

        <!-- PM : ne voit que ses propres annonces -->
        <record id="rule_annonce_pm" model="ir.rule">
            <field name="name">PM : ses annonces uniquement</field>
            <field name="model_id" ref="model_gespro_annonce"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_pm'))]"/>
        </record>

        <!-- TECH : lecture seule sur appels en préparation -->
        <record id="rule_appel_tech" model="ir.rule">
            <field name="name">TECH : lecture appels en préparation</field>
            <field name="model_id" ref="model_gespro_appel"/>
            <field name="domain_force">[('state', '=', 'en_preparation')]</field>
            <field name="groups" eval="[(4, ref('group_tech'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- TECH : ne voit QUE ses checklists techniques + peut les modifier -->
        <record id="rule_checklist_tech" model="ir.rule">
            <field name="name">TECH : checklists techniques uniquement</field>
            <field name="model_id" ref="model_gespro_checklist_line"/>
            <field name="domain_force">[('categorie', '=', 'tech')]</field>
            <field name="groups" eval="[(4, ref('group_tech'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

         <!-- FIN : lecture seule sur appels en préparation ou prêts -->
        <record id="rule_appel_fin" model="ir.rule">
            <field name="name">FIN : lecture appels en préparation</field>
            <field name="model_id" ref="model_gespro_appel"/>
            <field name="domain_force">[('state', 'in', ['en_preparation', 'pret'])]</field>
            <field name="groups" eval="[(4, ref('group_fin'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

       <!-- FIN : ne voit QUE ses checklists financières + peut les modifier -->
        <record id="rule_checklist_fin" model="ir.rule">
            <field name="name">FIN : checklists financières uniquement</field>
            <field name="model_id" ref="model_gespro_checklist_line"/>
            <field name="domain_force">[('categorie', '=', 'fin')]</field>
            <field name="groups" eval="[(4, ref('group_fin'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>


        <!-- RESADMIN : lecture seule sur appels en préparation -->
        <record id="rule_appel_resadmin" model="ir.rule">
            <field name="name">RESADMIN : lecture appels</field>
            <field name="model_id" ref="model_gespro_appel"/>
            <field name="domain_force">[('state', 'in', ['en_preparation', 'pret', 'soumis', 'gagne', 'perdu'])]</field>
            <field name="groups" eval="[(4, ref('group_resadmin'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>
        
        <!-- RESADMIN : ne voit QUE ses checklists admin + peut les modifier -->
        <record id="rule_checklist_resadmin" model="ir.rule">
            <field name="name">RESADMIN : checklists admin uniquement</field>
            <field name="model_id" ref="model_gespro_checklist_line"/>
            <field name="domain_force">[('categorie', '=', 'admin')]</field>
            <field name="groups" eval="[(4, ref('group_resadmin'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- PM : lecture seule sur toutes les checklists -->
        <record id="rule_checklist_pm" model="ir.rule">
            <field name="name">PM : lecture checklists</field>
            <field name="model_id" ref="model_gespro_checklist_line"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_pm'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- CEO : accès complet (pas de règle = tout voir) -->

    </data>
</odoo>